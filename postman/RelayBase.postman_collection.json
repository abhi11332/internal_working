{
  "info": {
    "_postman_id": "relaybase-collection",
    "name": "RelayBase API Collection",
    "description": "Postman collection for RelayBase authentication, article, admin, and bookmark APIs.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Abhishek Kumar\",\n  \"email\": \"abhi@example.com\",\n  \"password\": \"123456\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/register",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "register"
              ]
            }
          }
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{adminEmail}}\",\n  \"password\": \"{{adminPassword}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "login"
              ]
            }
          }
        },
        {
          "name": "Get Current User",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/auth/me",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "me"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Articles",
      "item": [
        {
          "name": "Get Published Articles",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/articles",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "articles"
              ]
            }
          }
        },
        {
          "name": "Get Article By Id",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/articles/{{articleId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "articles",
                "{{articleId}}"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Admin Articles",
      "item": [
        {
          "name": "Get All Articles",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/admin/articles",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "admin",
                "articles"
              ]
            }
          }
        },
        {
          "name": "Create Article",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"RelayBase API Overview\",\n  \"content\": \"This article explains how the RelayBase API is structured and secured.\",\n  \"category\": \"TECH\",\n  \"tags\": [\"api\", \"relaybase\", \"docs\"]\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/admin/articles",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "admin",
                "articles"
              ]
            }
          }
        },
        {
          "name": "Update Article",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"RelayBase API Overview Updated\",\n  \"content\": \"This updated article explains the versioned RelayBase API structure.\",\n  \"category\": \"TECH\",\n  \"tags\": [\"api\", \"relaybase\", \"v1\"]\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/admin/articles/{{articleId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "admin",
                "articles",
                "{{articleId}}"
              ]
            }
          }
        },
        {
          "name": "Update Article Status",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"PUBLISHED\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/admin/articles/{{articleId}}/status",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "admin",
                "articles",
                "{{articleId}}",
                "status"
              ]
            }
          }
        },
        {
          "name": "Delete Article",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/admin/articles/{{articleId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "admin",
                "articles",
                "{{articleId}}"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Bookmarks",
      "item": [
        {
          "name": "Get Bookmarks",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/bookmarks",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "bookmarks"
              ]
            }
          }
        },
        {
          "name": "Add Bookmark",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/bookmarks/{{articleId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "bookmarks",
                "{{articleId}}"
              ]
            }
          }
        },
        {
          "name": "Remove Bookmark",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/bookmarks/{{articleId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "bookmarks",
                "{{articleId}}"
              ]
            }
          }
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "https://internal-working.onrender.com/api/v1"
    },
    {
      "key": "token",
      "value": ""
    },
    {
      "key": "articleId",
      "value": ""
    },
    {
      "key": "adminEmail",
      "value": "abhi@gmail.com"
    },
    {
      "key": "adminPassword",
      "value": "123456"
    }
  ]
}
